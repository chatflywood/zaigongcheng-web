{
  "name": "zaigongcheng-app",
  "productName": "工程建设数据驾舱",
  "version": "1.14.0",
  "description": "在建工程和预算下达的自动化分析系统",
  "main": "electron/main.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "vite build && electron-builder --mac --dir"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "echarts": "^6.0.0",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "gh-pages": "^6.3.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.zaigongcheng.app",
    "productName": "工程建设数据驾舱",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": "dir"
    },
    "asar": true
  }
}
